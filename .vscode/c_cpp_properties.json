        "${workspaceFolder}/**",
        "${workspaceFolder}/Inc",
        "${workspaceFolder}/Src",
        "${workspaceFolder}/Mcu/f421/Inc",
        "${workspaceFolder}/Mcu/f421/Src",
        "${workspaceFolder}/Mcu/f421/Drivers/CMSIS/cm4/core_support",
